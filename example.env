# Supabase
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# JWT - Obtenlo en: Supabase Dashboard > Settings > API > JWT Secret
JWT_SECRET=your-supabase-jwt-secret

# Google Drive - OAuth2 (cuenta personal, usa los 15 GB gratis del Gmail)
# 1. Google Cloud Console > APIs y servicios > Credenciales > Crear credenciales
#    > ID de cliente de OAuth > Tipo "Aplicación de escritorio"
# 2. Copia el Client ID y Client Secret aquí
# 3. Ejecuta: go run ./cmd/oauth-token  para obtener el refresh token
GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_OAUTH_REFRESH_TOKEN=your-refresh-token
# ID de la carpeta de Drive donde se guardarán las imágenes (visible en la URL de la carpeta)
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id

# Server
PORT=8080
